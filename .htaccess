# ═══════════════════════════════════════════════════════════════
# Master of Illusion — Корневой .htaccess
# ═══════════════════════════════════════════════════════════════

Options -Indexes
ServerSignature Off

# ── HTTPS принудительный редирект ────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTP → HTTPS (через Nginx reverse proxy — проверяем X-Forwarded-Proto)
    RewriteCond %{HTTP:X-Forwarded-Proto} ^http$
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Запрет доступа к служебным файлам ────────────────────────────
<FilesMatch "^(\.env|\.env\.example|\.git|composer\.json|composer\.lock|package\.json|package-lock\.json|.*\.sql|.*\.log|.*\.sh)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Запрет доступа к директориям с конфигурацией и миграциями
<IfModule mod_rewrite.c>
    RewriteRule ^(include_config|migrations|logs)(/|$) - [F,L]
</IfModule>

# ── Заголовки безопасности ────────────────────────────────────────
<IfModule mod_headers.c>
    # Запрет встраивания в iframe (кликджекинг)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Запрет MIME-сниффинга
    Header always set X-Content-Type-Options "nosniff"

    # XSS-защита браузера (IE/Edge legacy)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy — не раскрываем URL при переходах на другие сайты
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS — принудительный HTTPS на 1 год
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy — разрешаем ресурсы только со своего домена и известных CDN
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://www.transparenttextures.com; media-src 'self' blob:; connect-src 'self'; frame-ancestors 'self';"

    # Запрет передачи Referer при переходе на внешние сайты
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Убираем информацию о сервере
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── MIME типы аудио + поддержка Range-запросов для плеера ────────
<IfModule mod_mime.c>
    AddType audio/mpeg        .mp3
    AddType audio/wav         .wav
    AddType audio/ogg         .ogg
    AddType audio/flac        .flac
    AddType video/mp4         .mp4
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(mp3|wav|ogg|flac|mp4)$">
        Header set Accept-Ranges bytes
    </FilesMatch>
</IfModule>

# ── Сжатие (Gzip) для ускорения ──────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Кеширование статики ───────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg  "access plus 30 days"
    ExpiresByType image/png   "access plus 30 days"
    ExpiresByType image/webp  "access plus 30 days"
    ExpiresByType image/gif   "access plus 30 days"
    ExpiresByType text/css    "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# ── Защита PHP-файлов в папке assets (только статика) ────────────
<IfModule mod_rewrite.c>
    RewriteRule ^assets/.*\.php$ - [F,L]
</IfModule>
