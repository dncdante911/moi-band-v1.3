# Режим работы
APP_ENV=development
APP_DEBUG=true

# Настройки базы данных
DB_HOST=localhost
DB_PORT=3306
DB_NAME=change_me
DB_USER=change_me
DB_PASS=change_me
DB_CHARSET=utf8mb4

# Настройки сайта
SITE_NAME="Master of Illusion"
SITE_URL=https://example.com
SITE_EMAIL=info@example.com

# Сессии
SESSION_LIFETIME=3600
SESSION_NAME=moi_session

# Загрузка файлов
MAX_UPLOAD_SIZE=104857600

# Логи
LOG_LEVEL=warning
LOG_PATH=/var/www/moi-band/logs/

# Безопасность
# JWT_SECRET — сгенерируй командой: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change_me

# Учётные данные администратора
# Хеш пароля генерируется: php admin/generate_password_hash.php
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=change_me

# API (если используется)
FOSSBILLING_API_URL=
FOSSBILLING_API_TOKEN=
