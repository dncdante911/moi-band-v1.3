# Настройки приложения
APP_ENV=development
APP_DEBUG=true

# Настройки базы данных
DB_HOST=localhost
DB_PORT=3306
DB_NAME=moi-band
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Настройки сайта
SITE_NAME="Master of Illusion"
SITE_URL=http://localhost
SITE_EMAIL=info@moi-band.com.ua

# Сессии
SESSION_LIFETIME=3600
SESSION_NAME=moi_session

# Загрузка файлов
MAX_UPLOAD_SIZE=104857600

# Логи
LOG_LEVEL=info
LOG_PATH=/path/to/logs

# Безопасность
# Сгенерируй случайный ключ: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=replace_with_random_64_char_hex_string

# Учётные данные администратора
# Хеш пароля: php admin/generate_password_hash.php
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2y$10$replace_this_with_real_bcrypt_hash

# API (если используется)
FOSSBILLING_API_URL=
FOSSBILLING_API_TOKEN=
